<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Restock Alert</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
        padding: 20px;
      }

      .container {
        max-width: 600px;
        margin: auto;
        background: #ffffff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      .header {
        text-align: center;
        color: #ffffff;
        background: #dc2626;
        padding: 12px;
        border-radius: 6px;
        font-size: 18px;
        font-weight: bold;
      }

      .content {
        margin-top: 20px;
        color: #333;
        line-height: 1.6;
      }

      .highlight {
        font-weight: bold;
        color: #111;
      }

      .priority {
        margin-top: 10px;
        padding: 8px;
        border-radius: 4px;
        display: inline-block;
        font-weight: bold;
      }

      .high {
        background: #fee2e2;
        color: #b91c1c;
      }

      .medium {
        background: #fef3c7;
        color: #92400e;
      }

      .footer {
        margin-top: 20px;
        font-size: 12px;
        color: #777;
        text-align: center;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        🚨 AI Inventory Restock Alert
      </div>

      <div class="content">
        <p>
          The system has detected a restock requirement for the following vehicle:
        </p>

        <p><span class="highlight">Model:</span> <%= model %></p>
        <p><span class="highlight">Current Stock:</span> <%= stock %></p>
        <p><span class="highlight">Sales (Last 7 Days):</span> <%= sales %></p>

        <p>
          <span class="highlight">Recommended Quantity:</span>
          <%= recommendedQty %>
        </p>

        <p>
          <span class="highlight">Priority:</span>
          <span class="priority <%= priority.toLowerCase() %>">
            <%= priority %>
          </span>
        </p>

        <p>
          <span class="highlight">Reason:</span><br />
          <%= reason %>
        </p>
      </div>

      <div class="footer">
        This alert was generated automatically by your AI Inventory System.
      </div>
    </div>
  </body>
</html>