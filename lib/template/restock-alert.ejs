<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Restock Alert</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f6f8;
        padding: 20px;
      }

      .container {
        max-width: 800px;
        margin: auto;
        background: #ffffff;
        padding: 20px;
        border-radius: 8px;
      }

      .header {
        text-align: center;
        color: #ffffff;
        background: #dc2626;
        padding: 12px;
        border-radius: 6px;
        font-size: 18px;
        font-weight: bold;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }

      th, td {
        padding: 10px;
        border: 1px solid #ddd;
        text-align: center;
      }

      th {
        background: #f3f4f6;
      }

      .high {
        color: #b91c1c;
        font-weight: bold;
      }

      .medium {
        color: #92400e;
        font-weight: bold;
      }

      .footer {
        margin-top: 20px;
        font-size: 12px;
        text-align: center;
        color: #777;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        🚨 AI Inventory Restock Alert
      </div>

      <table>
        <thead>
          <tr>
            <th>Model</th>
            <th>Stock</th>
            <th>Sales</th>
            <th>Priority</th>
            <th>Qty</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td><%= item.model %></td>
              <td><%= item.stock %></td>
              <td><%= item.sales %></td>
              <td class="<%= item.priority.toLowerCase() %>">
                <%= item.priority %>
              </td>
              <td><%= item.recommendedQty %></td>
              <td><%= item.reason %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="footer">
        Generated by AI Inventory System
      </div>
    </div>
  </body>
</html>